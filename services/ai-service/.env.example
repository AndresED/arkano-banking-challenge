PORT=3003
DATABASE_URL=postgres://bank:bank@localhost:5432/ai
KAFKA_BROKERS=localhost:19092

# En local: true recomendado. Si es false, el primer arranque puede leer solo mensajes
# nuevos tras unirse al grupo (~10–20s con Redpanda) y perder TransactionCompleted ya publicados.
KAFKA_CONSUMER_FROM_BEGINNING=true

# LLM: mock por defecto. Para Ollama local:
# USE_OLLAMA=true
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_TIMEOUT_MS=120000
# Loguea en consola el JSON enviado a /api/chat y el cuerpo crudo de respuesta (false = solo tamaños/URL).
# OLLAMA_LOG_IO=true
